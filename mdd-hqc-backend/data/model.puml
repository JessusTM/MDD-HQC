@startuml
title MDD-HQC
class "ExecuteQuantumAnnealingAlgorithm" as C1 <<Quantum>> {
  QuantumComputer : String
  QuantumComputingInstance : String
}
note right of C1
  mandatory: QuantumComputer, QuantumComputingInstance
  actor: Quantum Module
end note
class "GenerateRoutePlan" as C2 <<Quantum>> {
  NationalMap : String
  VehicleFleet : String
  CurrentDemand : String
  ExecuteGraphAlgorithm() : void
  DetermineRequiredComputingType() : void
  PrepareAndRequestQuantumComputation() : void
}
note right of C2
  mandatory: NationalMap, VehicleFleet, CurrentDemand, DetermineRequiredComputingType
  actor: Route Planning System
  contribution: hurt -> EfficientResourceUsage
  contribution: hurt -> ComputationTime
  contribution: break -> ScalabilityUnderHighDemand
  contribution: make -> RoutePlanQuality
  ExecuteGraphAlgorithm(): mandatory: ClassicalComputer
  DetermineRequiredComputingType(): or: ExecuteGraphAlgorithm, PrepareAndRequestQuantumComputation
end note
class "PerformDelivery" as C3 {
  fastDelivery : String = true
  optimalResourceUsage : String = true
}
note right of C3
  actor: ChileEsPres
end note
C2 ..> C1 : requires
C3 ..> C2 : requires
@enduml
